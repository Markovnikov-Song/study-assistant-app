# ── 必填 ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_CHAT_MODEL=deepseek-ai/DeepSeek-V3
LLM_EMBEDDING_MODEL=BAAI/bge-m3

# ── 共享配置（开发者/朋友使用）──────────────────────────────────────────────
# 用户通过口令验证后，会使用这些配置
DEV_LLM_BASE_URL=https://api.openai.com/v1
DEV_LLM_API_KEY=sk-proj-...
DEV_VISION_BASE_URL=https://api.openai.com/v1
DEV_VISION_API_KEY=sk-proj-...

# ── LLM 模型配置 ───────────────────────────────────────────────────────────────
LLM_VISION_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# 场景化模型（可选，不填则所有场景使用 LLM_CHAT_MODEL）
# LLM_FAST_MODEL=qwen2.5-7b-instruct      # 轻量：简单问答、标题生成、hints
# LLM_HEAVY_MODEL=deepseek-ai/DeepSeek-R1 # 重量：解题、讲义生成、council

# ── RAG 向量检索参数 ───────────────────────────────────────────────────────────
# SIMILARITY_THRESHOLD=0.7   # cosine 距离阈值，越小越严格
# CHUNK_SIZE=800              # 文档分块大小（字符数）
# CHUNK_OVERLAP=150           # 分块重叠大小
# TOP_K=8                     # 检索返回的最大片段数

# ── LLM 调用参数（各场景独立可调）────────────────────────────────────────────
# LLM_MEMORY_TEMPERATURE=0.1          # 记忆提取：低温保证 JSON 格式稳定
# LLM_MEMORY_MAX_TOKENS=800
# LLM_LECTURE_TEMPERATURE=0.3         # 讲义生成：低温保证结构一致
# LLM_LECTURE_MAX_TOKENS=4096
# LLM_NOTES_POLISH_TEMPERATURE=0.3    # 笔记润色：低温保持原意
# LLM_NOTES_POLISH_MAX_TOKENS=2000
# LLM_HINTS_TEMPERATURE=0.8           # 提问建议：高温增加多样性
# LLM_HINTS_MAX_TOKENS=200
# LLM_SKILL_PARSE_MAX_TOKENS=1000     # Skill 解析
# LLM_COUNCIL_SUBJECT_TEACHER_MAX_TOKENS=1500
# LLM_COUNCIL_PRINCIPAL_MAX_TOKENS=800
# LLM_COUNCIL_ADVISOR_MAX_TOKENS=800
# LLM_COUNCIL_DECISION_MAX_TOKENS=200
# LLM_COUNCIL_FEEDBACK_MAX_TOKENS=100
# LLM_SKILL_RECOMMEND_MAX_TOKENS=500
# LLM_EXECUTE_NODE_MAX_TOKENS=2000

# ── 业务逻辑阈值 ──────────────────────────────────────────────────────────────
# COMPANION_MISTAKE_THRESHOLD=5        # 同桌：错题数超过此值触发快反馈
# COMPANION_FOCUS_MINUTES_WARN=30      # 同桌：专注时长低于此值触发中反馈
# COMPANION_FOCUS_MINUTES_CRITICAL=20  # 同桌：专注时长低于此值触发慢反馈
# COUNCIL_DEVIATION_THRESHOLD_PERCENT=20  # 校长：进度偏差超过此百分比介入

# ── 采样与限制参数 ────────────────────────────────────────────────────────────
# MINDMAP_MAX_CHUNKS=60               # 思维导图：最多采样的 chunk 数
# EXAM_KNOWLEDGE_CHUNK_LIMIT=30       # 出题：知识点提取的 chunk 数
# EXAM_CUSTOM_CHUNK_LIMIT=20          # 出题：自定义出题的 chunk 数
# CHAT_HISTORY_WINDOW=40              # 对话历史：注入 LLM 的最近消息数
# MEMORY_WEAK_POINTS_MAX=8            # 用户记忆：薄弱点最大条数
# MEMORY_FREQUENT_TOPICS_MAX=8        # 用户记忆：常问话题最大条数
# MEMORY_MISCONCEPTIONS_MAX=5         # 用户记忆：误解最大条数
# HINTS_HISTORY_LIMIT=20              # Hints：取最近 N 条历史消息
# HINTS_COUNT=3                       # Hints：每次生成的建议数
# HINTS_MAX_CHARS=40                  # Hints：建议最大字符数
# SESSION_TITLE_MAX_CHARS=15          # 会话标题最大字符数

# ── 超时配置（秒）────────────────────────────────────────────────────────────
# LECTURE_GENERATION_TIMEOUT_SECONDS=120
# PDF_GENERATION_TIMEOUT_SECONDS=90
# MCP_TOOL_CALL_TIMEOUT_SECONDS=10.0
# MCP_RECONNECT_INTERVAL_SECONDS=30
# MCP_STOP_TIMEOUT_SECONDS=5

# ── 文件类型白名单 ────────────────────────────────────────────────────────────
# DOCUMENT_ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.txt,.md
# PAST_EXAM_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.docx

# ── 功能默认值 ────────────────────────────────────────────────────────────────
# DEFAULT_RAG_MODE=strict             # strict / broad / hybrid / solve
# DEFAULT_SKILL_PARSER_ADAPTER=ai     # ai / rule_based
# DEFAULT_SESSION_TYPE=qa             # qa / solve / mindmap / exam

# ── 认证配置 ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here
# JWT_EXPIRE_HOURS=168                # 默认 7 天

# ── 部署配置 ──────────────────────────────────────────────────────────────────
# 生产环境必须配置，多个域名用逗号分隔
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# 不配置时默认只允许 localhost（开发模式）

# ── 应用内更新配置 ────────────────────────────────────────────────────────────
# 每次发布新版本时修改以下三项，客户端启动时会自动检查
# APP_VERSION=1.0.0                   # 最新版本号
# APP_MIN_VERSION=1.0.0               # 最低支持版本（低于此版本强制更新）
# APP_DOWNLOAD_URL=http://47.104.165.105:8000/downloads/app-v1.0.0.apk
# APP_CHANGELOG=修复了若干问题，优化了性能
