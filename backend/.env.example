DATABASE_URL=postgresql://user:pass@host/dbname
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_CHAT_MODEL=deepseek-ai/DeepSeek-V3
LLM_EMBEDDING_MODEL=BAAI/bge-m3
LLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
JWT_SECRET=your-secret-key-here

# 场景化模型配置（可选，不填则所有场景使用 LLM_CHAT_MODEL）
# LLM_FAST_MODEL=qwen2.5-7b-instruct   # 轻量模型：简单问答、标题生成
# LLM_HEAVY_MODEL=deepseek-ai/DeepSeek-R1  # 重量模型：解题、讲义生成
